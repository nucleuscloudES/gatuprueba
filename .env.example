# URL remota para cargar courseData dinámico.
# Si falla esta carga, la app usa el fallback hardcodeado en src/data/courseData.js.
VITE_COURSE_DATA_URL=https://raw.githubusercontent.com/nucleuscloudES/gatuprueba/course-content/courseData.json

# Timeout de espera para la carga remota (en milisegundos)
VITE_COURSE_DATA_TIMEOUT_MS=8000
